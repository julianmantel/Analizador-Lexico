<Window x:Class="AnalizadorLexico.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Analizador Léxico — TP Teoría de Computabilidad"
        Height="850" Width="1300"
        MinHeight="700" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundMain}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0" Background="{StaticResource BackgroundToolbar}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="LexerView · C#" FontSize="16" FontWeight="Bold" Foreground="{StaticResource ForegroundMain}" VerticalAlignment="Center" Margin="0,0,40,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="btnAnalizar" Content="▶  Analizar" Width="110" Height="36"
                            Background="#2C2C2A" Foreground="White"
                            Style="{StaticResource BotonesEstilo}" Click="BtnAnalizar_Click"/>

                    <Button x:Name="btnLimpiar" Content="Limpiar" Width="90" Height="36" Margin="12,0,0,0"
                            Background="White" Foreground="#2C2C2A"
                            Style="{StaticResource BotonesEstilo}" Click="BtnLimpiar_Click"/>

                    <TextBlock Text="Ejemplos:" VerticalAlignment="Center" Margin="30,0,10,0" Foreground="{StaticResource ForegroundLight}"/>

                    <Button x:Name="btnSimple" Content="Simple" Width="90" Height="36"
                            Background="White" Foreground="{StaticResource AccentPurple}"
                            Style="{StaticResource BotonesEstilo}" Click="BtnSimple_Click"/>

                    <Button x:Name="btnIntermedio" Content="Intermedio" Width="100" Height="36" Margin="8,0,0,0"
                            Background="White" Foreground="{StaticResource AccentGreen}"
                            Style="{StaticResource BotonesEstilo}" Click="BtnIntermedio_Click"/>

                    <Button x:Name="btnError" Content="Con errores" Width="105" Height="36" Margin="8,0,0,0"
                            Background="White" Foreground="{StaticResource AccentError}"
                            Style="{StaticResource BotonesEstilo}" Click="BtnError_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ESTADÍSTICAS -->
        <Border Grid.Row="1" Background="{StaticResource BackgroundMain}" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total tokens -->
                <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Total tokens" FontSize="14" Foreground="#707070" Margin="0,8,0,4" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtTotal" Text="—" FontSize="32" FontWeight="Bold" Foreground="{StaticResource ForegroundMain}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>

                <!-- Palabras reservadas -->
                <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Palabras reservadas" FontSize="14" Foreground="#707070" Margin="0,8,0,4" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtReservadas" Text="—" FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentPurple}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>

                <!-- Identificadores -->
                <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Identificadores" FontSize="14" Foreground="#707070" Margin="0,8,0,4" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtIdentificadores" Text="—" FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>

                <!-- Errores -->
                <Border Grid.Column="3" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4" Margin="4,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Errores léxicos" FontSize="14" Foreground="#707070" Margin="0,8,0,4" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtErrores" Text="—" FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentError}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Código fuente -->
            <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4" Margin="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F5F5F3" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                        <TextBlock Text="  Código fuente" FontSize="11" Foreground="{StaticResource ForegroundLight}" VerticalAlignment="Center"/>
                    </Border>
                    <RichTextBox x:Name="rtbCodigo" Grid.Row="1"
                              FontFamily="Consolas" FontSize="20"
                                 Background="#FCFCFB" Foreground="#2C2C2A"
                                 AcceptsTab="True" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 BorderThickness="0" Padding="8">
                        <RichTextBox.Resources>
                            <Style TargetType="Paragraph">
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </RichTextBox.Resources>
                    </RichTextBox>
                </Grid>
            </Border>

            <!-- Tabla de tokens -->
            <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4" Margin="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F5F5F3" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                        <TextBlock Text="  Tabla de tokens" FontSize="11" Foreground="{StaticResource ForegroundLight}" VerticalAlignment="Center"/>
                    </Border>
                    <DataGrid x:Name="dgTokens" Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource BorderColor}"
                              RowBackground="White"
                              AlternatingRowBackground="#FAFAFA"
                              BorderThickness="0"
                                 FontFamily="Consolas" FontSize="20"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Width="50" Binding="{Binding Numero}" IsReadOnly="True">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#2C2C2A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="10,6"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Lexema" Width="*" Binding="{Binding Lexema}" IsReadOnly="True">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#2C2C2A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="6,4"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="4,2"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Tipo" Width="*">
                                <DataGridTemplateColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#2C2C2A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="6,4"/>
                                    </Style>
                                </DataGridTemplateColumn.HeaderStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Tipo}" Foreground="{Binding TipoColor}" FontWeight="SemiBold" Padding="4,2" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- BARRA DE ESTADO -->
        <Border Grid.Row="3" Background="{StaticResource BackgroundStatus}">
            <TextBlock x:Name="txtStatus" Text="  Listo — ingresa código y presiona Analizar"
                       Foreground="White" FontSize="11" FontFamily="Segoe UI"
                       VerticalAlignment="Center" Padding="12,0,0,0"/>
        </Border>
    </Grid>
</Window>